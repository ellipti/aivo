  },

  "actions": {
    "on_data_anomaly": "PAUSE_15M",
    "on_drift": "SAFE_MODE",
    "on_perf_cliff": "PAUSE_2H"
  },

  "alerts": {
    "telegram": true,
    "webhook": null
  }
}
