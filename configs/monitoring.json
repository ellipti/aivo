{
  "symbols": ["XAUUSD", "EURUSD"],
  "timeframe": "M30",
  "point": { "XAUUSD": 0.1, "EURUSD": 0.0001 },

  "data_integrity": {
    "max_gap_bars": 3,
    "max_wick_ratio": 8.0,
    "zero_spread_bars_cap": 1
  },

  "feature_drift": {
    "window_bars": 500,
    "ks_threshold": 0.18,
